{
  "name": "ecomexperts-eval-task",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "json-server --watch data/db.json --routes data/routes.json --port 3001 --host 0.0.0.0",
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run api\" \"npm run dev\"",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/node": "8.0.0",
    "@react-router/serve": "8.0.0",
    "@tanstack/react-query": "^5.101.0",
    "isbot": "^5.1.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0"
  },
  "devDependencies": {
    "@qpokychuk/gilroy": "^1.0.2",
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "json-server": "^0.17.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  }
}
